@code {
    private static readonly string[] Actions =
    [
        "search", "view_details", "play_trailer", "add_to_watchlist",
        "rate_movie", "browse_genre", "view_recommendations"
    ];

    private static readonly Random Rng = new();

    private static readonly string DefaultPolicyExpanded = "{\n  \"indexingMode\": \"consistent\",\n  \"automatic\": true,\n  \"includedPaths\": [\n    {\n      \"path\": \"/*\"\n    }\n  ],\n  \"excludedPaths\": [\n    {\n      \"path\": \"/\\\"_etag\\\"/?\"\n    }\n  ]\n}";

    private static readonly string ImplicitPolicyExpanded = "{\n  \"indexingMode\": \"consistent\",\n  \"automatic\": true,\n  \"includedPaths\": [\n    {\n      \"path\": \"/*\"\n    }\n  ],\n  \"excludedPaths\": [\n    {\n      \"path\": \"/client/*\"\n    },\n    {\n      \"path\": \"/geo/*\"\n    },\n    {\n      \"path\": \"/performance/*\"\n    },\n    {\n      \"path\": \"/context/*\"\n    },\n    {\n      \"path\": \"/\\\"_etag\\\"/?\"\n    }\n  ]\n}";

    private static readonly string ExplicitPolicyExpanded = "{\n  \"indexingMode\": \"consistent\",\n  \"automatic\": true,\n  \"includedPaths\": [\n    {\n      \"path\": \"/timestamp/?\"\n    }\n  ],\n  \"excludedPaths\": [\n    {\n      \"path\": \"/*\"\n    },\n    {\n      \"path\": \"/\\\"_etag\\\"/?\"\n    }\n  ]\n}";

    private bool isLoading;
    private bool observerSetUp;
    private string? activeContainer;
    private readonly Dictionary<string, string?> errors = new()
    {
        ["Default"] = null, ["Implicit"] = null, ["Explicit"] = null
    };
    private readonly Dictionary<string, IndexingResponse?> responses = new()
    {
        ["Default"] = null, ["Implicit"] = null, ["Explicit"] = null
    };
    private BrowsingEvent? sharedEvent;

    // Indexed top-level property names per policy
    private static readonly HashSet<string> ExcludedImplicit = new(StringComparer.OrdinalIgnoreCase)
        { "client", "geo", "performance", "context" };
    private static readonly HashSet<string> IncludedExplicit = new(StringComparer.OrdinalIgnoreCase)
        { "timestamp" };

    protected override void OnInitialized()
    {
        Benchmark.OnChange += StateHasChanged;
        Benchmark.Clear();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!observerSetUp && HasAnyCosts())
        {
            observerSetUp = true;
            await JS.InvokeVoidAsync("eval", @"
                (function() {
                    if (window.__ixCostObserver) window.__ixCostObserver.disconnect();
                    var el = document.getElementById('section-Summary');
                    if (!el) return;
                    window.__ixCostObserver = new IntersectionObserver(function(entries) {
                        var tracker = document.querySelector('.ix-cost-tracker');
                        if (!tracker) return;
                        entries.forEach(function(e) {
                            if (e.isIntersecting) tracker.classList.add('ix-cost-minimized');
                            else tracker.classList.remove('ix-cost-minimized');
                        });
                    }, { threshold: 0.1 });
                    window.__ixCostObserver.observe(el);
                })()
            ");
        }
    }

    private async Task WriteEventForContainer(string container)
    {
        isLoading = true;
        activeContainer = container;
        errors[container] = null;

        try
        {
            var action = Actions[Rng.Next(Actions.Length)];
            var resp = await Api.SimulateEventAsync(action);

            if (resp is null)
            {
                errors[container] = "Failed to write event. Is the API running?";
                return;
            }

            responses[container] = resp;
            sharedEvent ??= resp.Event;

            var result = resp.Results.FirstOrDefault(r => r.Container == container);
            if (result is not null)
                Benchmark.RecordWrite(container, result.RequestCharge);

            await ScrollToResults(container);
        }
        catch (Exception ex)
        {
            errors[container] = $"Error: {ex.Message}";
        }
        finally
        {
            isLoading = false;
            activeContainer = null;
        }
    }

    private void ResetContainer(string container)
    {
        responses[container] = null;
        errors[container] = null;
    }

    private async Task StartOver()
    {
        foreach (var key in responses.Keys.ToList())
        {
            responses[key] = null;
            errors[key] = null;
        }
        sharedEvent = null;
        Benchmark.Clear();
        observerSetUp = false;
        await ScrollToSection("Default");
    }

    private bool HasAnyCosts() =>
        Benchmark.ContainerNames.Any(c => Benchmark.GetTotalRU(c) > 0);

    private double GetContainerRU(string container)
    {
        var resp = responses[container];
        return resp?.Results.FirstOrDefault(r => r.Container == container)?.RequestCharge ?? 0;
    }

    private async Task ScrollToResults(string container)
    {
        await Task.Yield();
        await JS.InvokeVoidAsync("eval", $"document.getElementById('steps-{container}')?.scrollIntoView({{behavior:'smooth',block:'start'}})");
    }

    private async Task ScrollToSection(string container)
    {
        await JS.InvokeVoidAsync("eval", $"document.getElementById('section-{container}')?.scrollIntoView({{behavior:'smooth',block:'start'}})");
    }

    private static string StepLabel(string text, bool loading, bool done)
    {
        if (loading) return "Working…";
        if (done) return $"✓ {text}";
        return text;
    }

    private static string GetInfoText(string container) => container switch
    {
        "Default" => "With all paths indexed, every property in the document contributes to the RU cost. This is the most expensive write but guarantees any future query pattern is supported without policy changes.",
        "Implicit" => "By excluding the client, geo, performance, and context paths, fewer properties are indexed on write — reducing the RU cost while still supporting flexible queries on other fields.",
        "Explicit" => "Only /timestamp is indexed — the write cost is minimal. This is ideal for high-throughput ingestion where you know the exact query patterns, but requires careful management as application queries evolve.",
        _ => ""
    };

    private static string FormatHighlightedJson(BrowsingEvent evt, string container)
    {
        var json = JsonSerializer.Serialize(evt, new JsonSerializerOptions
        {
            WriteIndented = true,
            PropertyNamingPolicy = JsonNamingPolicy.CamelCase
        });

        var lines = json.Split('\n');
        var sb = new System.Text.StringBuilder();
        sb.Append("<pre class=\"ix-json-highlighted\">");

        string? currentTopKey = null;
        int braceDepth = 0;
        bool inExcludedBlock = false;

        foreach (var rawLine in lines)
        {
            var trimmed = rawLine.TrimStart();

            // Track brace depth for nested objects
            if (currentTopKey is not null)
            {
                foreach (var ch in trimmed)
                {
                    if (ch == '{' || ch == '[') braceDepth++;
                    else if (ch == '}' || ch == ']') braceDepth--;
                }
                if (braceDepth <= 0)
                {
                    currentTopKey = null;
                    braceDepth = 0;
                }
            }

            // Detect top-level property key
            if (currentTopKey is null && trimmed.StartsWith("\""))
            {
                var keyEnd = trimmed.IndexOf('"', 1);
                if (keyEnd > 1)
                {
                    var key = trimmed[1..keyEnd];
                    bool isIndexed = IsPropertyIndexed(key, container);

                    // Check if this starts a nested block
                    if (trimmed.Contains('{') || trimmed.Contains('['))
                    {
                        currentTopKey = key;
                        braceDepth = 0;
                        foreach (var ch in trimmed)
                        {
                            if (ch == '{' || ch == '[') braceDepth++;
                            else if (ch == '}' || ch == ']') braceDepth--;
                        }
                        inExcludedBlock = !isIndexed;
                    }
                    else
                    {
                        inExcludedBlock = !isIndexed;
                    }

                    var cssClass = isIndexed ? "ix-highlight-indexed" : "ix-highlight-excluded";
                    sb.Append($"<span class=\"{cssClass}\">");
                    sb.Append(System.Net.WebUtility.HtmlEncode(rawLine));
                    sb.AppendLine("</span>");
                    if (currentTopKey is null) inExcludedBlock = false;
                    continue;
                }
            }

            if (currentTopKey is not null)
            {
                var cssClass = inExcludedBlock ? "ix-highlight-excluded" : "ix-highlight-indexed";
                sb.Append($"<span class=\"{cssClass}\">");
                sb.Append(System.Net.WebUtility.HtmlEncode(rawLine));
                sb.AppendLine("</span>");
            }
            else
            {
                sb.AppendLine(System.Net.WebUtility.HtmlEncode(rawLine));
            }
        }

        sb.Append("</pre>");
        return sb.ToString();
    }

    private static bool IsPropertyIndexed(string propertyName, string container) => container switch
    {
        "Default" => true,
        "Implicit" => !ExcludedImplicit.Contains(propertyName),
        "Explicit" => IncludedExplicit.Contains(propertyName),
        _ => true
    };

    public void Dispose()
    {
        Benchmark.OnChange -= StateHasChanged;
        _ = JS.InvokeVoidAsync("eval", "if(window.__ixCostObserver){window.__ixCostObserver.disconnect();window.__ixCostObserver=null;}");
    }
}
