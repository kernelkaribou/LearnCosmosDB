@page "/modules/indexing"
@using System.Text.Json
@using LearnCosmosDB.Shared.Indexing
@using Microsoft.JSInterop
@inject IndexingApiClient Api
@inject IndexingBenchmarkService Benchmark
@inject IJSRuntime JS
@implements IDisposable

<PageTitle>Indexing - Learn Cosmos DB</PageTitle>

<div class="page-header">
    <h1>Indexing</h1>
    <span class="page-subtitle">See how indexing strategies affect the RU cost of writes</span>
</div>

@* ══════════════════════════════════════════════════════════════════
   Section 1 — About
   ══════════════════════════════════════════════════════════════════ *@
<section class="ix-guide-section">
    <h2>About Indexing in Azure Cosmos DB</h2>
    <p>
        Being a schema-agnostic database, Cosmos DB will automatically
        <a href="https://learn.microsoft.com/en-us/azure/cosmos-db/index-overview" target="_blank">index</a>
        every property for each item in your containers. This can be highly beneficial from a query performance
        perspective while not requiring administration effort. Unlike reads where RU cost is influenced by document
        model, query patterns and document size, write RU costs are almost exclusively impacted by the
        indexing policies in place.
    </p>
    <h3>Scenario</h3>
    <p>
        Taking our data modeling movie scenario further, this demonstration focuses on three indexing policy strategies: Default, Implicit, and Explicit focusing on how
        each affects the RU cost when writing the same document to containers with different policies.
        Each browsing event contains information both useful for the user experience and telemetry for the applcation. This is written
        to an event container that each have their own defined indexing policy. 
        <span class="ix-highlight-indexed">Highlighted fields</span> in the event document indicate which properties are indexed by that policy.
    </p>
</section>

@* ══════════════════════════════════════════════════════════════════
   Section 2 — Default
   ══════════════════════════════════════════════════════════════════ *@
<section class="ix-guide-section">
    <h2 id="section-Default">Default Policy</h2>
    <p>
        Without any configuration, Cosmos DB automatically indexes every property in each document. This is a
        hands-off approach that supports any query pattern but comes at the highest write cost since every
        property must be indexed.
    </p>

    <div class="ix-step-row" id="steps-Default">
        <button class="ix-step-btn @(responses["Default"] is not null ? "ix-step-done" : "ix-step-active")"
                disabled="@(isLoading || responses["Default"] is not null)"
                @onclick='() => WriteEventForContainer("Default")'>
            @StepLabel("Write Event", isLoading && activeContainer == "Default", responses["Default"] is not null)
        </button>
    </div>

    @if (errors["Default"] is not null)
    {
        <div class="error-message">@errors["Default"]</div>
    }

    @RenderPolicySection("Default", DefaultPolicyExpanded)
</section>

@* ══════════════════════════════════════════════════════════════════
   Section 3 — Implicit
   ══════════════════════════════════════════════════════════════════ *@
<section class="ix-guide-section">
    <h2 id="section-Implicit">Implicit Policy</h2>
    <p>
        The implicit strategy maintains the wildcard include (<code>/*</code>) but explicitly excludes paths we know
        will never be queried: <code>/client/*</code>, <code>/geo/*</code>, <code>/performance/*</code>,
        and <code>/context/*</code>. New properties outside those paths are still automatically indexed impicitly, giving
        flexibility for evolving query patterns but saving on known access patterns.
    </p>

    <div class="ix-step-row" id="steps-Implicit">
        <button class="ix-step-btn @(responses["Implicit"] is not null ? "ix-step-done" : "ix-step-active")"
                disabled="@(isLoading || responses["Implicit"] is not null)"
                @onclick='() => WriteEventForContainer("Implicit")'>
            @StepLabel("Write Event", isLoading && activeContainer == "Implicit", responses["Implicit"] is not null)
        </button>
    </div>

    @if (errors["Implicit"] is not null)
    {
        <div class="error-message">@errors["Implicit"]</div>
    }

    @RenderPolicySection("Implicit", ImplicitPolicyExpanded)
</section>

@* ══════════════════════════════════════════════════════════════════
   Section 4 — Explicit
   ══════════════════════════════════════════════════════════════════ *@
<section class="ix-guide-section">
    <h2 id="section-Explicit">Explicit Policy</h2>
    <p>
        When you know exactly which properties will be queried, you can include only those paths and exclude
        everything else with a wildcard being far more explicit in your indexing approach. Here we only index <code>/timestamp/?</code> allowing us
        to perform time-window queries we desire but giving us lowest possible write cost.
    </p>

    <div class="ix-step-row" id="steps-Explicit">
        <button class="ix-step-btn @(responses["Explicit"] is not null ? "ix-step-done" : "ix-step-active")"
                disabled="@(isLoading || responses["Explicit"] is not null)"
                @onclick='() => WriteEventForContainer("Explicit")'>
            @StepLabel("Write Event", isLoading && activeContainer == "Explicit", responses["Explicit"] is not null)
        </button>
    </div>

    @if (errors["Explicit"] is not null)
    {
        <div class="error-message">@errors["Explicit"]</div>
    }

    @RenderPolicySection("Explicit", ExplicitPolicyExpanded)
</section>

@* ══════════════════════════════════════════════════════════════════
   Section 5 — Summary
   ══════════════════════════════════════════════════════════════════ *@
<section id="section-Summary" class="ix-guide-section ix-guide-section-last">
    <h2>Summary</h2>
    <p>
        Indexing policies will directly control write costs. The Default policy gives maximum query flexibility at the
        highest write RU cost. The Explicit policy gives the lowest write cost but limits which properties can
        be queried efficiently. The Implicit policy provides a practical middle ground in scenarios where we have evolving application usage
        but also identifying known properties that do not need to be indexed.
    </p>

    @{
        bool allComplete = responses.Values.All(r => r is not null);
    }
    @if (allComplete)
    {
        var defaultRU = GetContainerRU("Default");
        var implicitRU = GetContainerRU("Implicit");
        var explicitRU = GetContainerRU("Explicit");
        var savings = defaultRU > 0 ? ((defaultRU - explicitRU) / defaultRU * 100) : 0;

        <div class="ix-summary-box">
            <h3>Indexing Policy RU Cost Results</h3>
            <table class="ix-summary-table">
                <thead>
                    <tr>
                        <th></th>
                        <th>Default</th>
                        <th>Implicit</th>
                        <th>Explicit</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td class="ix-row-label">Write RU</td>
                        <td>@defaultRU.ToString("F2")</td>
                        <td>@implicitRU.ToString("F2")</td>
                        <td class="ix-summary-best-cell">@explicitRU.ToString("F2")</td>
                    </tr>
                    <tr>
                        <td class="ix-row-label">× 1,000/sec</td>
                        <td>@((defaultRU * 1000).ToString("N0"))</td>
                        <td>@((implicitRU * 1000).ToString("N0"))</td>
                        <td class="ix-summary-best-cell">@((explicitRU * 1000).ToString("N0"))</td>
                    </tr>
                </tbody>
            </table>
            <div class="ix-summary-savings">
                The Explicit policy saved <strong>@savings.ToString("F0")%</strong> in write RU cost compared to Default.
                At 1,000 writes/sec that's <strong>@(((defaultRU - explicitRU) * 1000).ToString("N0")) RU/s</strong> saved.
            </div>
            <div style="text-align: right;">
                <button class="ix-start-over-btn" @onclick="StartOver">↺ Start Over</button>
            </div>
        </div>
    }
    <p>
        Cosmos DB has two indexing modes outside of the defined policies: <em>Consistent</em> (default, synchronous during write) and <em>None</em>
        (disabled). Indexing policies are configured at the container level and can be updated at any time. Indexes
        also consume storage, so intentional policies can  not only reduce compute costs but also reduce storage costs in scenarios where simply not needed.
    </p>
    <p>
        There is no one-size-fits-all policy. Review your application's query patterns, write throughput, and
        tolerance for index management to choose the right strategy for each container.
    </p>
    <p>
        <a href="/demos/indexing" class="ix-demo-link">Indexing Demo</a>
        to write multiple events in parallel to compare costs.
    </p>
</section>

@* ══════════════════════════════════════════════════════════════════
   Floating Cost Comparison
   ══════════════════════════════════════════════════════════════════ *@
@if (HasAnyCosts())
{
    <div class="ix-cost-tracker">
        <div class="ix-cost-mini"><img src="learncosmos.webp" alt="LearnCosmosDB" class="ix-cost-mini-logo" /></div>
        <div class="ix-cost-full">
            <div class="ix-cost-header">
                <span class="ix-cost-title">Cost Comparison</span>
                <button class="ix-cost-clear" title="Reset all" @onclick="StartOver">↺</button>
            </div>
            <table class="ix-cost-table">
                <thead>
                    <tr>
                        <th>Default</th>
                        <th>Implicit</th>
                        <th>Explicit</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        @foreach (var c in new[] { "Default", "Implicit", "Explicit" })
                        {
                            var ru = GetContainerRU(c);
                            <td class="@(ru > 0 ? "ix-cost-active" : "")">@(ru > 0 ? $"{ru:F2} RU" : "—")</td>
                        }
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
}

@* ══════════════════════════════════════════════════════════════════
   Render Fragments
   ══════════════════════════════════════════════════════════════════ *@
@{
    RenderFragment RenderPolicySection(string container, string policyJson) => __builder2 =>
    {
        var resp = responses[container];
        var ru = resp?.Results.FirstOrDefault(r => r.Container == container);

        <div class="ix-results-grid" id="results-@container">
            <div class="ix-results-left">
                <div class="ix-policy-card">
                    <div class="ix-policy-card-header">
                        <span>Indexing Policy</span>
                        @if (ru is not null)
                        {
                            <span class="ix-ru-badge">@ru.RequestCharge.ToString("F2") RU</span>
                        }
                    </div>
                    <pre class="doc-json ix-policy-pre">@policyJson</pre>
                </div>
                @if (resp is not null)
                {
                    <div class="guide-callout guide-callout-info">
                        <strong>Info:</strong> @GetInfoText(container)
                    </div>
                }
            </div>
            <div class="ix-results-right">
                @if (resp is not null && sharedEvent is not null)
                {
                    <h3>Event Document</h3>
                    @((MarkupString)FormatHighlightedJson(sharedEvent, container))
                }
                else
                {
                    <div class="ix-placeholder">
                        Select <strong>'Write Event'</strong> to write a document with the <strong>@container</strong> policy
                    </div>
                }
            </div>
        </div>
    };
}

