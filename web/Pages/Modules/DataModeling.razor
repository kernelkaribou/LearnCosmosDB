@code {
    private DemoHints? hints;
    private readonly Dictionary<string, SectionState> sections = new()
    {
        ["Single"] = new(),
        ["Embedded"] = new(),
        ["Reference"] = new(),
        ["Hybrid"] = new()
    };
    private bool observerSetUp;

    private enum SectionStep { Ready, MovieDone, DirectorDone, DetailDone }

    private class SectionState
    {
        public SectionStep Step { get; set; } = SectionStep.Ready;
        public bool IsLoading { get; set; }
        public string? Error { get; set; }
        public DataModelingResponse? MovieResponse { get; set; }
        public DataModelingResponse? DirectorResponse { get; set; }
        public DataModelingResponse? DetailResponse { get; set; }
    }


    protected override async Task OnInitializedAsync()
    {
        Benchmark.OnChange += StateHasChanged;
        ResetAll();
        hints = await Api.GetHintsAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!observerSetUp && HasAnyCosts())
        {
            observerSetUp = true;
            await JS.InvokeVoidAsync("eval", @"
                (function() {
                    if (window.__costObserver) window.__costObserver.disconnect();
                    var el = document.getElementById('dm-page-end');
                    if (!el) return;
                    window.__costObserver = new IntersectionObserver(function(entries) {
                        var tracker = document.querySelector('.guide-cost-tracker');
                        if (!tracker) return;
                        entries.forEach(function(e) {
                            if (e.isIntersecting) tracker.classList.add('cost-minimized');
                            else tracker.classList.remove('cost-minimized');
                        });
                    }, { threshold: 0.1 });
                    window.__costObserver.observe(el);
                })()
            ");
        }
    }

    private string StepLabel(string text, bool loading, bool done)
    {
        if (loading) return "Working…";
        if (done) return $"✓ {text}";
        return text;
    }

    private async Task DoMovieSearch(string model)
    {
        if (hints?.MovieTitle is null) return;
        var sec = sections[model];
        sec.IsLoading = true;
        sec.Error = null;

        try
        {
            var type = model == "Single" ? "movie" : null;
            var resp = await Api.SearchAsync(model, hints.MovieTitle, type);
            if (resp is null) { sec.Error = "No results found."; return; }
            sec.MovieResponse = resp;
            sec.Step = SectionStep.MovieDone;
            RecordBenchmark(resp, "Movie Query");
            await ScrollToResults(model);
        }
        catch (Exception ex) { sec.Error = $"Error: {ex.Message}"; }
        finally { sec.IsLoading = false; }
    }

    private async Task DoDirectorSearch(string model)
    {
        if (hints?.TopDirectorName is null) return;
        var sec = sections[model];
        sec.IsLoading = true;
        sec.Error = null;

        try
        {
            var type = model == "Single" ? "person" : null;
            var resp = await Api.SearchAsync(model, hints.TopDirectorName, type);
            if (resp is null) { sec.Error = "No results found."; return; }
            sec.DirectorResponse = resp;
            sec.Step = SectionStep.DirectorDone;
            RecordBenchmark(resp, "Director Query");
            await ScrollToResults(model);
        }
        catch (Exception ex) { sec.Error = $"Error: {ex.Message}"; }
        finally { sec.IsLoading = false; }
    }

    private async Task DoDetailClick(string model)
    {
        var sec = sections[model];
        var dirResp = sec.DirectorResponse;
        if (dirResp is null || dirResp.MediaResults.Count == 0) return;

        string? movieId = null, movieTitle = null;
        var first = dirResp.MediaResults[0];
        var docType = GetProp(first, "type") ?? "movie";

        if (docType == "movie")
        {
            movieId = GetProp(first, "id");
            movieTitle = GetProp(first, "title");
        }
        else
        {
            var roles = GetRoles(first);
            if (roles.Count > 0)
            {
                movieId = roles[0].MovieId;
                movieTitle = roles[0].MovieTitle;
            }
            else
            {
                movieId = GetProp(first, "movieId");
                movieTitle = GetProp(first, "movieTitle");
            }
        }

        if (string.IsNullOrEmpty(movieId) || string.IsNullOrEmpty(movieTitle)) return;

        sec.IsLoading = true;
        sec.Error = null;

        try
        {
            var resp = await Api.SearchAsync(model, movieTitle, docId: movieId);
            if (resp is null) { sec.Error = "Document not found."; return; }
            sec.DetailResponse = resp;
            sec.Step = SectionStep.DetailDone;
            RecordBenchmark(resp, "Movie Point Read");
            await ScrollToResults(model);
        }
        catch (Exception ex) { sec.Error = $"Error: {ex.Message}"; }
        finally { sec.IsLoading = false; }
    }

    private void ResetSection(string model)
    {
        sections[model] = new SectionState();
        Benchmark.ClearModel(model);
    }

    private void ResetAll()
    {
        foreach (var key in sections.Keys.ToList())
            sections[key] = new SectionState();
        Benchmark.ClearModelCosts();
    }

    private async Task StartOver()
    {
        ResetAll();
        hints = await Api.GetHintsAsync();
        await ScrollToSection("Single");
    }

    private bool HasAnyCosts()
    {
        return Benchmark.ModelNames.Any(m => Benchmark.GetModelTotal(m) > 0);
    }

    private void RecordBenchmark(DataModelingResponse resp, string action)
    {
        if (resp.RequestDiagnostics is { } diag && double.TryParse(diag.RequestCharge, out var ru))
            Benchmark.RecordQuery(action, ru, diag.DataModel);
    }

    private async Task ScrollToResults(string model)
    {
        await Task.Yield();
        await JS.InvokeVoidAsync("eval", $"document.getElementById('steps-{model}')?.scrollIntoView({{behavior:'smooth',block:'start'}})");
    }

    private async Task ScrollToSection(string model)
    {
        await JS.InvokeVoidAsync("eval", $"document.getElementById('section-{model}')?.scrollIntoView({{behavior:'smooth',block:'start'}})");
    }

    private static (DataModelingResponse? Response, string Label) GetActiveResponse(SectionState sec)
    {
        if (sec.DetailResponse is not null) return (sec.DetailResponse, "Select Movie (Point Read)");
        if (sec.DirectorResponse is not null) return (sec.DirectorResponse, "Director Search");
        if (sec.MovieResponse is not null) return (sec.MovieResponse, "Movie Search");
        return (null, "");
    }

    private static string? GetProp(JsonElement el, string prop)
    {
        if (el.ValueKind != JsonValueKind.Object || !el.TryGetProperty(prop, out var val))
            return null;
        return val.ValueKind switch
        {
            JsonValueKind.String => val.GetString(),
            JsonValueKind.Number => val.GetRawText(),
            JsonValueKind.True => "true",
            JsonValueKind.False => "false",
            JsonValueKind.Null => null,
            _ => val.GetRawText()
        };
    }

    private static List<(string MovieId, string MovieTitle, string RoleName, string? PosterUrl, string? Year, string? MpaaRating)> GetRoles(JsonElement el)
    {
        if (el.ValueKind != JsonValueKind.Object || !el.TryGetProperty("roles", out var roles) || roles.ValueKind != JsonValueKind.Array)
            return [];
        var result = new List<(string, string, string, string?, string?, string?)>();
        foreach (var role in roles.EnumerateArray())
        {
            var movieId = role.TryGetProperty("movieId", out var mi) ? mi.GetString() ?? "" : "";
            var movieTitle = role.TryGetProperty("movieTitle", out var mt) ? mt.GetString() ?? "" : "";
            var roleName = role.TryGetProperty("roleName", out var rn) ? rn.GetString() ?? "" : "";
            var posterUrl = role.TryGetProperty("posterUrl", out var pu) && pu.ValueKind == JsonValueKind.String ? pu.GetString() : null;
            var year = role.TryGetProperty("year", out var y) && y.ValueKind == JsonValueKind.Number ? y.GetRawText() : null;
            var mpaaRating = role.TryGetProperty("mpaaRating", out var mr) && mr.ValueKind == JsonValueKind.String ? mr.GetString() : null;
            result.Add((movieId, movieTitle, roleName, posterUrl, year, mpaaRating));
        }
        return result;
    }

    private static string FormatJson(JsonElement el)
    {
        return JsonSerializer.Serialize(el, new JsonSerializerOptions { WriteIndented = true });
    }

    private static List<string> GetArray(JsonElement el, string prop)
    {
        if (el.ValueKind != JsonValueKind.Object || !el.TryGetProperty(prop, out var arr) || arr.ValueKind != JsonValueKind.Array)
            return [];
        var result = new List<string>();
        foreach (var item in arr.EnumerateArray())
        {
            var name = item.TryGetProperty("name", out var n) ? n.GetString() : null;
            if (!string.IsNullOrEmpty(name)) result.Add(name);
        }
        return result;
    }

    private static List<(string Name, string OriginalName, string? ImageUrl)> GetPeople(JsonElement el, string prop)
    {
        if (el.ValueKind != JsonValueKind.Object || !el.TryGetProperty(prop, out var arr) || arr.ValueKind != JsonValueKind.Array)
            return [];
        var result = new List<(string, string, string?)>();
        foreach (var item in arr.EnumerateArray())
        {
            var name = item.TryGetProperty("name", out var n) ? n.GetString() ?? "" : "";
            var originalName = item.TryGetProperty("originalName", out var on) && on.ValueKind == JsonValueKind.String
                ? on.GetString() ?? name : name;
            var imageUrl = item.TryGetProperty("imageUrl", out var img) && img.ValueKind == JsonValueKind.String
                ? img.GetString() : null;
            result.Add((name, originalName, imageUrl));
        }
        return result;
    }

    private static List<(string Review, string Score)> GetReviews(JsonElement el)
    {
        if (el.ValueKind != JsonValueKind.Object || !el.TryGetProperty("reviews", out var arr) || arr.ValueKind != JsonValueKind.Array)
            return [];
        var result = new List<(string, string)>();
        foreach (var item in arr.EnumerateArray())
        {
            var review = item.TryGetProperty("criticReview", out var r) && r.ValueKind == JsonValueKind.String
                ? r.GetString() ?? "" : "";
            var score = item.TryGetProperty("criticScore", out var s) && s.ValueKind == JsonValueKind.Number
                ? s.GetRawText() : "";
            result.Add((review, score));
        }
        return result;
    }

    public void Dispose()
    {
        Benchmark.OnChange -= StateHasChanged;
        _ = JS.InvokeVoidAsync("eval", "if(window.__costObserver){window.__costObserver.disconnect();window.__costObserver=null;}");
    }
}
